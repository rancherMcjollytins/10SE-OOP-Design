        }
      ],
      "updated": 1781654924999,
      "link": null,
      "locked": false,
      "text": "A player in the game. can get\nand can play\ncards/attributes. Has a hand\nof cards (dealt by the deck)\nand can win the game by\ngetting the most cards at the\nend.",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A player in the game. can get and can play cards/attributes. Has a hand of cards (dealt by the deck) and can win the game by getting the most cards at the end.",
      "autoResize": false,
      "lineHeight": 1.25
    },
